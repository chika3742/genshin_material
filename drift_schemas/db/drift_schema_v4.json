          "sql": "CREATE TABLE IF NOT EXISTS \"in_game_weapon_state_table\" (\"uid\" TEXT NOT NULL, \"character_id\" TEXT NOT NULL, \"weapon_id\" TEXT NOT NULL, \"purposes\" TEXT NOT NULL, \"last_updated\" INTEGER NOT NULL DEFAULT (CAST(strftime('%s', CURRENT_TIMESTAMP) AS INTEGER)), PRIMARY KEY (\"uid\", \"character_id\", \"weapon_id\"));"
        }
