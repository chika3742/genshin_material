  "fixed_sql": [
    {
      "name": "bookmark_material_group_table",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"bookmark_material_group_table\" (\"group_hash\" TEXT NOT NULL, \"character_id\" TEXT NOT NULL, \"weapon_id\" TEXT NULL, \"purpose_type\" TEXT NOT NULL, \"created_at\" INTEGER NOT NULL DEFAULT (CAST(strftime('%s', CURRENT_TIMESTAMP) AS INTEGER)), \"order_index\" TEXT NOT NULL UNIQUE, PRIMARY KEY (\"group_hash\"));"
        }
      ]
    },
    {
      "name": "bookmark_material_item_table",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"bookmark_material_item_table\" (\"hash\" TEXT NOT NULL, \"group_hash\" TEXT NOT NULL REFERENCES bookmark_material_group_table (group_hash) ON DELETE CASCADE, \"material_id\" TEXT NULL, \"quantity\" INTEGER NOT NULL, \"upper_level\" INTEGER NOT NULL, PRIMARY KEY (\"hash\"));"
        }
      ]
    },
    {
      "name": "bookmark_artifact_table",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"bookmark_artifact_table\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"character_id\" TEXT NOT NULL, \"created_at\" INTEGER NOT NULL DEFAULT (CAST(strftime('%s', CURRENT_TIMESTAMP) AS INTEGER)), \"sub_stats\" TEXT NOT NULL, \"order_index\" TEXT NOT NULL UNIQUE);"
        }
      ]
    },
    {
      "name": "bookmark_artifact_set_table",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"bookmark_artifact_set_table\" (\"id\" INTEGER NOT NULL REFERENCES bookmark_artifact_table (id) ON DELETE CASCADE, \"sets\" TEXT NOT NULL, \"main_stats\" TEXT NOT NULL, PRIMARY KEY (\"id\"));"
        }
      ]
    },
    {
      "name": "bookmark_artifact_piece_table",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"bookmark_artifact_piece_table\" (\"id\" INTEGER NOT NULL REFERENCES bookmark_artifact_table (id) ON DELETE CASCADE, \"piece\" TEXT NOT NULL, \"main_stat\" TEXT NULL, PRIMARY KEY (\"id\"));"
        }
      ]
    },
    {
      "name": "in_game_character_state_table",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"in_game_character_state_table\" (\"uid\" TEXT NOT NULL, \"character_id\" TEXT NOT NULL, \"purposes\" TEXT NOT NULL, \"equipped_weapon_id\" TEXT NULL, \"last_updated\" INTEGER NOT NULL DEFAULT (CAST(strftime('%s', CURRENT_TIMESTAMP) AS INTEGER)), PRIMARY KEY (\"uid\", \"character_id\"));"
        }
      ]
    },
    {
      "name": "in_game_weapon_state_table",
