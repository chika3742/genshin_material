# update_fastlane

require "yaml"

PLAY_STORE_RELEASE_NOTES_LENGTH_LIMIT = 500

locale_map = {
  "ja" => "ja-JP",
  "en" => "en-US",
}

continue_message_map = {
  "ja" => "\n続きはアプリ内の更新履歴をご覧ください。",
  "en" => "\nSee the full release notes in the app.",
}

def truncate_release_notes(content, max_length, continue_message)
  return content if content.length <= max_length

  available_length = max_length - continue_message.length
  truncated = ""
  content.each_line do |line|
    break if (truncated + line).length > available_length
    truncated += line
  end
  truncated.rstrip + continue_message
end

default_platform(:android)

platform :android do
    desc "Deploy a new version to the Google Play"
    lane :upload do
        app_version = ENV["APP_VERSION"]
        is_test_version = ENV["DEPLOY_CHANNEL"] != "prod"

        Dir.chdir("../../build/app/intermediates/merged_native_libs/release/mergeReleaseNativeLibs/out/lib") do
            sh("zip -r ../../../../../../../../android/native_debug_symbols.zip ./* -x *x86/*")
        end

        if !is_test_version
            contents = YAML.safe_load(File.read("../../assets/release_notes.yaml"))
            version_entry = contents.find { |e| e["version"] == app_version }
            if version_entry == nil
                raise "No release note for version #{app_version}. Did you add it?"
            end
            version_entry["contents"]["locales"].each do |locale, contents|
                path = "./metadata/android/#{locale_map[locale]}/changelogs/default.txt"
                FileUtils.mkdir_p(File.dirname(path))
                truncated = truncate_release_notes(contents, PLAY_STORE_RELEASE_NOTES_LENGTH_LIMIT, continue_message_map[locale])
                File.write(path, truncated)
            end
        end

        upload_to_play_store(
            aab: "../build/app/outputs/bundle/release/app-release.aab",
            mapping_paths: ["../build/app/outputs/mapping/release/mapping.txt", "./native_debug_symbols.zip"],
            track: is_test_version ? "internal" : "production",
            release_status: is_test_version ? "completed" : "draft",
            skip_upload_metadata: true,
            skip_upload_images: true,
            skip_upload_screenshots: true,
            changes_not_sent_for_review: true,
        )
    end

    lane :upload_screenshots do
        desc "Upload screenshots to the Google Play"
        upload_to_play_store(
            json_key: "/Users/chika/Documents/secrets/service_account_key/mydatauploader-cb1806f10377.json",
            track: "internal",
            skip_upload_aab: true,
            skip_upload_changelogs: true,
            skip_upload_images: true,
            changes_not_sent_for_review: true,
        )
    end
end
